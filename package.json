{
  "name": "@textmine/cli",
  "version": "0.1.0",
  "description": "TextMine CLI — a direct, scriptable REST client for the TextMine Public API V3.",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "textmine": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "build:bin": "bun build ./src/index.ts --compile --outfile dist/textmine",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
